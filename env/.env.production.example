# Production environment for the droplet Docker stack.
# Copy to env/.env.production and fill in — NEVER commit the real file.

DEBUG=false
SECRET_KEY=changeme-generate-a-long-random-string
PROD_HOSTS=cosound.ca,www.cosound.ca
WEB_CONCURRENCY=2

# Postgres (db container). Keep POSTGRES_PASSWORD and the password inside
# DATABASE_URL in sync — both must be edited when rotating it.
POSTGRES_PASSWORD=changeme
DATABASE_URL=postgres://cosound:changeme@db:5432/cosound

# AWS — S3 sound/media storage + SES auth email
AWS_ACCESS_KEY_ID=changeme
AWS_SECRET_ACCESS_KEY=changeme
AWS_STORAGE_BUCKET_NAME=changeme
AWS_S3_REGION_NAME=us-east-2

# First admin account, created on first container start
FIRST_ADMIN_EMAIL=changeme
FIRST_ADMIN_USERNAME=changeme
FIRST_ADMIN_PASSWORD=changeme

SERVER_REFRESH_INTERVAL=30
VOTE_THROTTLE_SECONDS=60
